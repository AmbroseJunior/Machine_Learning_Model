# ════════════════════════════════════════════════════════════════════════════
# ML Studio — Environment Variables
# Tech stack: Python · Supabase · Streamlit  (no Docker, no Node.js)
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your Supabase values (Settings → API in the dashboard)
# 3. NEVER commit .env — it contains secrets
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────────────────
# Get all three values from: Supabase dashboard → Settings → API

# Project URL  (safe to expose)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key  (safe to expose)
SUPABASE_ANON_KEY=your-anon-key

# Service role key  (PRIVATE — never share or commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
